# IBM watsonx
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Cloudant
CLOUDANT_URL=
CLOUDANT_API_KEY=

# IBM Cloud Object Storage (HMAC credentials)
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_ACCESS_KEY_ID=
COS_SECRET_ACCESS_KEY=
COS_BUCKET_NAME=lang-legacy-audio

# Local speech-to-text (faster-whisper — run `npm run whisper` in another terminal)
WHISPER_SERVER_URL=http://127.0.0.1:8000

# Google Cloud Text-to-Speech (IPA pronunciation via SSML phoneme — enable API + API key)
# https://cloud.google.com/text-to-speech/docs/basics
GOOGLE_CLOUD_TTS_API_KEY=
# Optional overrides (defaults: en-US / en-US-Neural2-D)
# GOOGLE_TTS_VOICE_LANGUAGE=en-US
# GOOGLE_TTS_VOICE_NAME=en-US-Neural2-D
